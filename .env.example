# Project UUID — owns your Postgres + storage buckets, AND scopes per-user
# api keys created at sign-up. After the Project Membership rollout, customers
# who sign up to this app become project_members of this project (not org
# members of the project's owning TruArc org). This is the primary env var.
RECURSIV_PROJECT_ID=

# Organization UUID — created by Recursiv MCP `provision_app` (or in the
# dashboard). Kept for legacy org-level operations (billing, team-wide
# settings); the auth flow now uses projectId.
RECURSIV_ORG_ID=

# Optional: override the API base URL (default: https://recursiv.io/api/v1).
# Only set when running against staging or a self-hosted Recursiv.
# RECURSIV_API_BASE_URL=

# NOTE: There is intentionally no RECURSIV_API_KEY env var here.
# This template uses the per-user API key pattern: each user's key is created
# at sign-up via signUpAndCreateKey, stored in an HTTP-only cookie, and used
# for every subsequent SDK call. The deployed app holds no god platform key.
